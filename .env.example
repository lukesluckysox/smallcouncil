# ─────────────────────────────────────────────────────────────────────────────
# Small Council — Environment Variables
# Copy this file to .env.local for local development
# All variables are required unless marked optional
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL connection string (Railway provides this automatically)
DATABASE_URL=postgresql://user:password@host:5432/railway

# Anthropic API key — get from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Claude model to use — update to latest stable Sonnet when upgrading
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Session secret — generate with: openssl rand -hex 32
# Must be at least 32 characters
SESSION_SECRET=your-long-random-secret-here

# The public URL of your app (no trailing slash)
# In Railway: set to your Railway-generated domain
APP_URL=http://localhost:3000

# Node environment
NODE_ENV=development
