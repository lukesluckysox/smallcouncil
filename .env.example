# ─── Database ─────────────────────────────────────────────────────────────────
# Path to the SQLite file.
# Railway: set this to the path inside your mounted volume, e.g. /data/smallcouncil.db
# Local dev: leave unset — defaults to <project>/data/smallcouncil.db
DATABASE_PATH=/data/smallcouncil.db

# ─── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SESSION_SECRET=replace-with-32-byte-hex-string

# ─── App ──────────────────────────────────────────────────────────────────────
APP_URL=https://your-app.up.railway.app
NODE_ENV=production
